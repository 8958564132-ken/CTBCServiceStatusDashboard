    <!-- Recent Updates -->
    <div class="recent-updates">
        <div class="updates-header">
            <div class="updates-title">
                <i class="fas fa-history"></i>
                <span>Recent Updates</span>
                <span class="update-count" id="update-count">0</span>
            </div>
            <button class="clear-btn" id="clear-updates">
                <i class="fas fa-trash-alt"></i> Clear
            </button>
        </div>
        <div class="updates-list" id="recent-updates-list">
            <div class="update-item">
                <div class="update-service">No recent updates</div>
            </div>
        </div>
    </div>
</div>

<audio id="alert-sound" src="https://ctbchovmadmwst.chinatrust.com.ph/monitoring/tada.wav"></audio>

@section Scripts {
    <script>
        // Store recent updates
        let recentUpdates = [];
        const MAX_UPDATES = 20;

        const urls = {
            "Swift Scan": "https://amla.chinatrust.com.ph:10548/OnlineSwiftScan_Rest/SwiftAction/swiftmethod",
            "Name Screening": "https://amla.chinatrust.com.ph:10548/OnlineScan_Server/services/OnlineScanServiceAction?wsdl",
            "Risk Score": "https://amla.chinatrust.com.ph:10548/OnlineRiskScore_Server/services/OnlineScanService?wsdl",
            "GBP Web Main": "https://gbp.chinatrust.com.ph",
            "Branch Channel": "https://gbp.chinatrust.com.ph/branchportal/Main.action#!",
            "GBP Rest API": "https://gbp.chinatrust.com.ph/gbprest/swagger-ui/index.html",
            "GBP Branch Rest API": "https://gbp.chinatrust.com.ph/branchrest/swagger-ui.html",
            "BST Revamp": "https://bst.chinatrust.com.ph/",
            "CIB 1.0 Client": "https://corp.ctbcnetbanking.com.ph",
            "CIB 1.0 Back Office": "https://corp.ctbcnetbanking.com.ph/corp/AuthenticationController?__START_TRAN_FLAG__=Y&FORMSGROUP_ID__=RMAuthenticationFG&__EVENT_ID__=LOAD&FG_BUTTONS__=LOAD&ACTION.LOAD=Y&RMAuthenticationFG.LOGIN_FLAG=2&BANK_ID=003&LANGUAGE_ID=001",
            "RIB 2.0 Net Banking": "https://retail.ctbcnetbanking.com.ph/web/",
            "CMMC": "https://cmmc.chinatrust.com.ph/",
            "OOB Back End": "https://bo-online-account.ctbcbank.com.ph/online-account-application/bo",
            "API Gateway Admin": "https://apim-admincnsl.ctbcbank.com.ph/login",
            "PDC Revamp": "https://pdc.chinatrust.com.ph/"
        };

        // Set initial status data so cells aren't blank
        function setInitialStatus() {
            const initialStatus = {
                "Swift Scan": { status: "online", lastChecked: "2 min ago" },
                "Name Screening": { status: "online", lastChecked: "3 min ago" },
                "Risk Score": { status: "online", lastChecked: "5 min ago" },
                "GBP Web Main": { status: "online", lastChecked: "2 min ago" },
                "Branch Channel": { status: "online", lastChecked: "4 min ago" },
                "GBP Rest API": { status: "online", lastChecked: "3 min ago" },
                "GBP Branch Rest API": { status: "checking", lastChecked: "1 min ago" },
                "API Gateway Admin": { status: "online", lastChecked: "2 min ago" },
                "PDC Revamp": { status: "online", lastChecked: "3 min ago" },
                "BST Revamp": { status: "online", lastChecked: "4 min ago" },
                "CIB 1.0 Client": { status: "online", lastChecked: "2 min ago" },
                "CIB 1.0 Back Office": { status: "offline", lastChecked: "6 min ago" },
                "RIB 2.0 Net Banking": { status: "online", lastChecked: "3 min ago" },
                "CMMC": { status: "checking", lastChecked: "1 min ago" },
                "OOB Back End": { status: "online", lastChecked: "5 min ago" }
            };

            for (const [label, data] of Object.entries(initialStatus)) {
                const statusElement = document.querySelector(`.status[data-label="${label}"]`);
                const lastCheckedElement = document.querySelector(`.last-checked[data-label="${label}"]`);
                
                if (statusElement && lastCheckedElement) {
                    if (data.status === 'online') {
                        statusElement.innerHTML = '<i class="fas fa-check-circle"></i> Online';
                        statusElement.classList.add('online');
                    } else if (data.status === 'offline') {
                        statusElement.innerHTML = '<i class="fas fa-times-circle"></i> Offline';
                        statusElement.classList.add('offline');
                    } else {
                        statusElement.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';
                    }
                    
                    lastCheckedElement.textContent = data.lastChecked;
                }
            }
        }

        function addRecentUpdate(serviceName, status, responseTime = null) {
            const now = new Date();
            const timeString = now.toLocaleTimeString();
            const dateString = now.toLocaleDateString();

            const update = {
                service: serviceName,
                status: status,
                time: timeString,
                date: dateString,
                timestamp: now.getTime(),
                responseTime: responseTime
            };

            recentUpdates.unshift(update);

            if (recentUpdates.length > MAX_UPDATES) {
                recentUpdates.pop();
            }

            displayRecentUpdates();
        }

        function displayRecentUpdates() {
            const updatesList = document.getElementById('recent-updates-list');
            const updateCount = document.getElementById('update-count');

            if (recentUpdates.length === 0) {
                updatesList.innerHTML = '<div class="update-item"><div class="update-service">No recent updates</div></div>';
                updateCount.textContent = '0';
                return;
            }

            updateCount.textContent = recentUpdates.length;

            let html = '';
            recentUpdates.forEach(update => {
                const statusIcon = update.status === 'online' ? 'fa-check-circle' : 'fa-times-circle';
                const statusClass = update.status === 'online' ? 'online' : 'offline';
                const responseTimeText = update.responseTime ? ` (${update.responseTime}ms)` : '';

                html += `
                    <div class="update-item">
                        <div class="update-status ${statusClass}">
                            <i class="fas ${statusIcon}"></i> ${update.status.toUpperCase()}
                        </div>
                        <div class="update-service">
                            ${update.service}${responseTimeText}
                        </div>
                        <div class="update-time">
                            <i class="far fa-clock"></i> ${update.time}
                        </div>
                        <span class="update-badge">${update.date}</span>
                    </div>
                `;
            });

            updatesList.innerHTML = html;
        }

        function clearRecentUpdates() {
            recentUpdates = [];
            displayRecentUpdates();
        }

        function playAlertSound() {
            const alertSound = document.getElementById("alert-sound");
            alertSound.play().catch(error => {
                console.error("Failed to play alert sound:", error);
            });
        }

        function updateStatusSummary() {
            const totalElements = document.querySelectorAll('.status').length;
            const onlineElements = document.querySelectorAll('.status.online').length;
            const offlineElements = document.querySelectorAll('.status.offline').length;

            document.getElementById('total-count').textContent = totalElements;
            document.getElementById('online-count').textContent = onlineElements;
            document.getElementById('offline-count').textContent = offlineElements;

            const now = new Date();
            document.getElementById('last-updated-time').textContent = now.toLocaleString();
        }

        async function checkUrl(url, label) {
            const statusElement = document.querySelector(`.status[data-label="${label}"]`);
            const lastCheckedElement = document.querySelector(`.last-checked[data-label="${label}"]`);
            
            if (!statusElement || !lastCheckedElement) return;

            statusElement.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';
            statusElement.className = "status";

            try {
                const startTime = performance.now();
                const response = await fetch(url, {
                    method: 'GET',
                    mode: 'no-cors',
                    cache: 'no-store'
                });
                const endTime = performance.now();
                const responseTime = Math.round(endTime - startTime);

                if (response.ok || response.status === 0) {
                    statusElement.innerHTML = `<i class="fas fa-check-circle"></i> Online (${responseTime}ms)`;
                    statusElement.classList.add('online');
                    addRecentUpdate(label, 'online', responseTime);
                } else {
                    statusElement.innerHTML = '<i class="fas fa-times-circle"></i> Offline';
                    statusElement.classList.add('offline');
                    addRecentUpdate(label, 'offline');
                    playAlertSound();
                }
            } catch (error) {
                statusElement.innerHTML = '<i class="fas fa-times-circle"></i> Offline';
                statusElement.classList.add('offline');
                addRecentUpdate(label, 'offline');
                playAlertSound();
            }

            const now = new Date().toLocaleTimeString();
            lastCheckedElement.textContent = now;
            updateStatusSummary();
        }

        function monitorUrls() {
            for (const [label, url] of Object.entries(urls)) {
                checkUrl(url, label);
            }
        }

        // Wait for DOM to be fully loaded before attaching event listeners
        document.addEventListener('DOMContentLoaded', function () {
            // Set initial status data immediately
            setInitialStatus();
            
            // Update summary counts based on initial data
            updateStatusSummary();
            
            // Manual refresh button
            document.getElementById('manual-refresh').addEventListener('click', function () {
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
                monitorUrls();
                setTimeout(() => {
                    this.innerHTML = '<i class="fas fa-redo-alt"></i> Refresh';
                }, 1000);
            });

            // Individual test buttons
            document.querySelectorAll('.test-btn').forEach(button => {
                button.addEventListener('click', function () {
                    const label = this.getAttribute('data-label');
                    const url = urls[label];
                    if (url) {
                        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';
                        this.disabled = true;
                        checkUrl(url, label).finally(() => {
                            setTimeout(() => {
                                this.innerHTML = 'Test';
                                this.disabled = false;
                            }, 500);
                        });
                    }
                });
            });

            // Clear updates button
            document.getElementById('clear-updates').addEventListener('click', function () {
                clearRecentUpdates();
            });

            // Initial check
            monitorUrls();
        });
    </script>
}