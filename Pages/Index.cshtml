@page
@model IndexModel
@using System.Security.Claims
@{
    ViewData["Title"] = "CTBC Service Status Dashboard";
    
    var isAuthenticated = User.Identity.IsAuthenticated;
    var userName = User.FindFirst("FullName")?.Value ?? "User";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    
    string dashboardUrl = "";
    if (userRole == "System Admin") dashboardUrl = "/SystemAdmin/Dashboard";
    else if (userRole == "User Admin") dashboardUrl = "/UserAdmin/Dashboard";
    else if (userRole == "LGU") dashboardUrl = "/LGU/Dashboard";
}

<style>
    .navbar {
        display: none !important;

    }
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: #0f172a;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #f8fafc;
        padding: 20px;
    }

    .dashboard {
        max-width: 1600px;
        margin: 0 auto;
        background: #1e293b;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid #334155;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    /* Header */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 16px;
        border-bottom: 1px solid #334155;
        min-height: 60px;
    }

    .header h1 {
        font-size: 28px;
        font-weight: 700;
        background: linear-gradient(135deg, #0ea5e9, #8b5cf6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-left: auto;
    }

    .last-updated {
        color: #94a3b8;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
        background: #0f172a;
        padding: 6px 12px;
        border-radius: 30px;
        border: 1px solid #334155;
    }

    .btn {
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #0ea5e9;
        color: white;
    }

    .btn-primary:hover {
        background: #0284c7;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid #334155;
        color: #f8fafc;
    }

    .btn-outline:hover {
        background: #334155;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
    }

    .btn-danger:hover {
        background: #dc2626;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #0f172a;
        border-radius: 12px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        border: 1px solid #334155;
        transition: transform 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        border-color: #0ea5e9;
    }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    .stat-icon.total {
        background: rgba(14, 165, 233, 0.15);
        color: #0ea5e9;
    }

    .stat-icon.online {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
    }

    .stat-icon.offline {
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
    }

    .stat-info h3 {
        color: #94a3b8;
        font-size: 14px;
        font-weight: 500;
        margin: 0 0 4px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-info p {
        color: white;
        font-size: 32px;
        font-weight: 700;
        margin: 0;
    }

    /* Tables */
    .tables-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .table-wrapper {
        background: #0f172a;
        border-radius: 12px;
        border: 1px solid #334155;
        overflow: hidden;
    }

    .table-header {
        padding: 16px;
        background: #1e293b;
        color: white;
        font-weight: 600;
        font-size: 16px;
        border-bottom: 1px solid #334155;
    }

    .table-header i {
        color: #0ea5e9;
        margin-right: 8px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        padding: 14px 16px;
        background: #0f172a;
        color: #94a3b8;
        font-weight: 600;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid #334155;
    }

    td {
        padding: 14px 16px;
        color: #f8fafc;
        border-bottom: 1px solid #334155;
        font-size: 14px;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:hover td {
        background: rgba(14, 165, 233, 0.05);
    }

    .application-badge {
        background: #1e293b;
        color: #0ea5e9;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        border: 1px solid #0ea5e9;
    }

    .status {
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status i {
        font-size: 14px;
    }

    .status.online {
        color: #10b981;
    }

    .status.offline {
        color: #ef4444;
    }

    .status .fa-spinner {
        color: #f59e0b;
    }

    .last-checked {
        color: #94a3b8;
        font-size: 12px;
    }

    .test-btn {
        background: transparent;
        border: 1px solid #334155;
        color: #94a3b8;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .test-btn:hover {
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: white;
    }

    /* Recent Updates */
    .recent-updates {
        background: #0f172a;
        border-radius: 12px;
        border: 1px solid #334155;
        overflow: hidden;
        margin-top: 20px;
    }

    .updates-header {
        padding: 16px;
        background: #1e293b;
        border-bottom: 1px solid #334155;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .updates-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        color: white;
    }

    .updates-title i {
        color: #0ea5e9;
    }

    .update-count {
        background: #0f172a;
        padding: 2px 10px;
        border-radius: 30px;
        font-size: 12px;
        color: #94a3b8;
        border: 1px solid #334155;
    }

    .updates-list {
        max-height: 250px;
        overflow-y: auto;
    }

    .update-item {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid #334155;
        gap: 16px;
    }

    .update-item:last-child {
        border-bottom: none;
    }

    .update-item:hover {
        background: rgba(14, 165, 233, 0.05);
    }

    .update-status {
        width: 70px;
        padding: 4px 8px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 600;
        text-align: center;
    }

    .update-status.online {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .update-status.offline {
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .update-service {
        flex: 1;
        color: white;
        font-weight: 500;
    }

    .update-time {
        color: #94a3b8;
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .update-badge {
        background: #1e293b;
        color: #94a3b8;
        padding: 2px 10px;
        border-radius: 30px;
        font-size: 11px;
    }

    .clear-btn {
        background: transparent;
        border: 1px solid #334155;
        color: #94a3b8;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .clear-btn:hover {
        background: #ef4444;
        border-color: #ef4444;
        color: white;
    }

    /* User badge for logged in users */
    .user-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #0f172a;
        padding: 4px 12px 4px 4px;
        border-radius: 30px;
        border: 1px solid #334155;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #0ea5e9, #8b5cf6);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 14px;
        color: white;
    }

    .user-name {
        color: white;
        font-size: 14px;
        font-weight: 500;
    }

    .user-role-badge {
        background: #334155;
        color: #94a3b8;
        padding: 2px 8px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .dashboard-link {
        display: flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #0ea5e9, #8b5cf6);
        color: white;
        text-decoration: none;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s;
    }

    .dashboard-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(14, 165, 233, 0.4);
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .tables-container {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        body { padding: 10px; }
        .dashboard { padding: 16px; }
        .stats-grid { grid-template-columns: 1fr; }
        .header { flex-direction: column; align-items: flex-start; gap: 16px; }
        .header-actions { flex-wrap: wrap; }
        .user-badge { width: 100%; justify-content: space-between; }
    }
</style>

<div class="dashboard">
    <!-- Header -->
    <div class="header">
        <h1>CTBC Service Status Dashboard</h1>
        <div class="header-actions">
            <span class="last-updated">
                <i class="fas fa-sync-alt"></i> <span id="last-updated-time">Just now</span>
            </span>
            <button class="btn btn-outline" id="manual-refresh">
                <i class="fas fa-redo-alt"></i> Refresh
            </button>
            
            @if (isAuthenticated)
            {
                <div class="user-badge">
                    <div class="user-avatar">
                        @userName.Substring(0, 1).ToUpper()
                    </div>
                    <span class="user-name">@userName</span>
                    <span class="user-role-badge">@userRole</span>
                </div>
                
                @if (!string.IsNullOrEmpty(dashboardUrl))
                {
                    <a href="@dashboardUrl" class="dashboard-link">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                }
                
                <a href="/Logout" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            }
            else
            {
                <a href="/Login" class="btn btn-primary">
                    <i class="fas fa-sign-in-alt"></i> Login
                </a>
            }
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-server"></i>
            </div>
            <div class="stat-info">
                <h3>Total Services</h3>
                <p id="total-count">0</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon online">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>Online</h3>
                <p id="online-count">0</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon offline">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="stat-info">
                <h3>Offline</h3>
                <p id="offline-count">0</p>
            </div>
        </div>
    </div>

    <!-- Tables -->
    <div class="tables-container">
        <!-- Left Table -->
        <div class="table-wrapper">
            <div class="table-header">
                <i class="fas fa-cube"></i> Applications & Services
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Application</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th>Last Checked</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="application-badge">AMLA</span></td>
                        <td>Swift Service</td>
                        <td class="status" data-label="Swift Scan"></td>
                        <td class="last-checked" data-label="Swift Scan"></td>
                        <td><button class="test-btn" data-label="Swift Scan">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">AMLA</span></td>
                        <td>Screening Service</td>
                        <td class="status" data-label="Name Screening"></td>
                        <td class="last-checked" data-label="Name Screening"></td>
                        <td><button class="test-btn" data-label="Name Screening">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">AMLA</span></td>
                        <td>Risk Score</td>
                        <td class="status" data-label="Risk Score"></td>
                        <td class="last-checked" data-label="Risk Score"></td>
                        <td><button class="test-btn" data-label="Risk Score">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">GBP</span></td>
                        <td>GBP Web Service</td>
                        <td class="status" data-label="GBP Web Main"></td>
                        <td class="last-checked" data-label="GBP Web Main"></td>
                        <td><button class="test-btn" data-label="GBP Web Main">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">GBP</span></td>
                        <td>Branch Channel</td>
                        <td class="status" data-label="Branch Channel"></td>
                        <td class="last-checked" data-label="Branch Channel"></td>
                        <td><button class="test-btn" data-label="Branch Channel">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">GBP</span></td>
                        <td>GBP Rest API</td>
                        <td class="status" data-label="GBP Rest API"></td>
                        <td class="last-checked" data-label="GBP Rest API"></td>
                        <td><button class="test-btn" data-label="GBP Rest API">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">GBP</span></td>
                        <td>Branch API Service</td>
                        <td class="status" data-label="GBP Branch Rest API"></td>
                        <td class="last-checked" data-label="GBP Branch Rest API"></td>
                        <td><button class="test-btn" data-label="GBP Branch Rest API">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">Kong</span></td>
                        <td>API Gateway Admin</td>
                        <td class="status" data-label="API Gateway Admin"></td>
                        <td class="last-checked" data-label="API Gateway Admin"></td>
                        <td><button class="test-btn" data-label="API Gateway Admin">Test</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Right Table -->
        <div class="table-wrapper">
            <div class="table-header">
                <i class="fas fa-cube"></i> Applications & Services
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Application</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th>Last Checked</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="application-badge">PDC</span></td>
                        <td>Revamp</td>
                        <td class="status" data-label="PDC Revamp"></td>
                        <td class="last-checked" data-label="PDC Revamp"></td>
                        <td><button class="test-btn" data-label="PDC Revamp">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">BST</span></td>
                        <td>Revamp</td>
                        <td class="status" data-label="BST Revamp"></td>
                        <td class="last-checked" data-label="BST Revamp"></td>
                        <td><button class="test-btn" data-label="BST Revamp">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">CIB 1.0</span></td>
                        <td>Client</td>
                        <td class="status" data-label="CIB 1.0 Client"></td>
                        <td class="last-checked" data-label="CIB 1.0 Client"></td>
                        <td><button class="test-btn" data-label="CIB 1.0 Client">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">CIB 1.0</span></td>
                        <td>Back Office</td>
                        <td class="status" data-label="CIB 1.0 Back Office"></td>
                        <td class="last-checked" data-label="CIB 1.0 Back Office"></td>
                        <td><button class="test-btn" data-label="CIB 1.0 Back Office">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">RIB 2.0</span></td>
                        <td>Net banking</td>
                        <td class="status" data-label="RIB 2.0 Net Banking"></td>
                        <td class="last-checked" data-label="RIB 2.0 Net Banking"></td>
                        <td><button class="test-btn" data-label="RIB 2.0 Net Banking">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">CMMC</span></td>
                        <td>CMMC</td>
                        <td class="status" data-label="CMMC"></td>
                        <td class="last-checked" data-label="CMMC"></td>
                        <td><button class="test-btn" data-label="CMMC">Test</button></td>
                    </tr>
                    <tr>
                        <td><span class="application-badge">OOB</span></td>
                        <td>Back End</td>
                        <td class="status" data-label="OOB Back End"></td>
