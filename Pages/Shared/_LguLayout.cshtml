@using System.Security.Claims
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/lgu/layout.css" />

<div class="lgu-wrapper">
    <!-- Sidebar -->
    <div class="lgu-sidebar" id="sidebar">
        <div class="sidebar-header">
            <h3>LGU Portal</h3>
            <p>Service Status Dashboard</p>
        </div>
        
        <div class="sidebar-nav">
            <ul class="nav-item">
                <li>
                    <a href="/LGU/Dashboard" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("Dashboard") ? "active" : "")">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                
                <li>
                    <a href="/LGU/Projects" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("Projects") ? "active" : "")">
                        <i class="fas fa-project-diagram"></i>
                        <span>Projects</span>
                    </a>
                </li>
                
                <li>
                    <a href="/LGU/Remittance" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("Remittance") ? "active" : "")">
                        <i class="fas fa-hand-holding-usd"></i>
                        <span>Remittances</span>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="lgu-content">
        <div class="lgu-header">
            <div style="display: flex; align-items: center;">
                <button class="toggle-sidebar" id="toggleSidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            
            <div class="user-info">
    <div class="user-details">
        <div class="user-name">@(User.FindFirst("FullName")?.Value ?? "User")</div>
        <div class="user-role">@(User.FindFirst(ClaimTypes.Role)?.Value ?? "Guest")</div>
    </div>
    <div class="user-avatar">
        @{
            var fullName = User.FindFirst("FullName")?.Value;
            var initial = !string.IsNullOrEmpty(fullName) && fullName.Length > 0 
                ? fullName.Substring(0, 1) 
                : "U";
        }
        @initial
    </div>
    
    <!-- SIMPLE LOGOUT LINK THAT WORKS -->
    <a href="/Logout" class="logout-btn">
        <i class="fas fa-sign-out-alt"></i> Logout
    </a>
</div>
        </div>
        
        <div class="lgu-body">
            @RenderBody()
        </div>
    </div>
</div>

<script>
    document.getElementById('toggleSidebar').addEventListener('click', function() {
        document.getElementById('sidebar').classList.toggle('collapsed');
    });
</script>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}