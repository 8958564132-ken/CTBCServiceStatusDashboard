@using System.Security.Claims
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/admin/system-admin-layout.css" />

<div class="admin-wrapper">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h3>System Admin</h3>
            <p>Service Status Dashboard</p>
        </div>
        
        <div class="sidebar-nav">
            <div class="nav-section-title">DASHBOARD</div>
            <a href="/SystemAdmin/Dashboard" class="nav-link">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            
            <div class="nav-section-title">URL MANAGEMENT</div>
            <a href="/SystemAdmin/UrlManagement" class="nav-link">
                <i class="fas fa-link"></i>
                <span>URLs</span>
            </a>
            <a href="/SystemAdmin/PingHistory" class="nav-link">
                <i class="fas fa-history"></i>
                <span>Ping History</span>
            </a>
            
            <div class="nav-section-title">AUDIT & LOGS</div>
            <a href="/SystemAdmin/AuditLogs" class="nav-link">
                <i class="fas fa-clipboard-list"></i>
                <span>Audit Logs</span>
            </a>
            <a href="/SystemAdmin/Reports" class="nav-link">
                <i class="fas fa-chart-bar"></i>
                <span>Reports</span>
            </a>
            
            <div class="nav-section-title">SETTINGS</div>
            <a href="/SystemAdmin/SystemSettings" class="nav-link">
                <i class="fas fa-cog"></i>
                <span>System Settings</span>
            </a>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="admin-content">
        <div class="admin-header">
            <h1 class="page-title">@ViewData["Title"]</h1>
            
            <div class="user-info">
                <div class="user-details">
                    <div class="user-name">@(User.FindFirst("FullName")?.Value ?? "System Admin")</div>
                    <div class="user-role">@(User.FindFirst(ClaimTypes.Role)?.Value ?? "Admin")</div>
                </div>
                <div class="user-avatar">
                    @{
                        var name = User.FindFirst("FullName")?.Value ?? "A";
                        var initial = name.Length > 0 ? name.Substring(0, 1) : "A";
                    }
                    @initial
                </div>
                <a href="/Logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
        
        <div class="admin-body">
            @RenderBody()
        </div>
    </div>
</div>

<script>
    document.getElementById('toggleSidebar').addEventListener('click', function() {
        document.getElementById('sidebar').classList.toggle('collapsed');
    });
</script>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}