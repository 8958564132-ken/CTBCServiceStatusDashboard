@page
@model UrlManagementModel
@{
    ViewData["Title"] = "URL Management";
    Layout = "_SystemAdminLayout";
}

<link rel="stylesheet" href="~/css/admin/url-management.css" />


@using CTBCServiceStatusDashboard.Models



<div class="url-management-container">
    <!-- Header -->
    <div class="header-section">
        <div class="header-title">
            <h1><i class="fas fa-link"></i> URL Management</h1>
            <p>Manage and monitor all your service URLs</p>
        </div>
        <button class="add-btn" onclick="showAddModal()">
            <i class="fas fa-plus"></i> Add New URL
        </button>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @Model.SuccessMessage
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <!-- Filters -->
    <form method="get" class="filters-section">
        <input type="text" 
               name="searchTerm" 
               class="search-box" 
               placeholder="Search by name, server, or IP address..." 
               value="@Model.SearchTerm" />
        
        <select name="statusFilter" class="filter-select">
            <option value="all">All Status</option>
            <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
            <option value="inactive" selected="@(Model.StatusFilter == "inactive")">Inactive</option>
        </select>
        
        <button type="submit" class="filter-btn">
            <i class="fas fa-search"></i> Apply Filters
        </button>
    </form>

    <!-- URLs Table -->
    <div class="table-responsive">
        <table class="url-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Server</th>
            <th>IP Address</th>
            <th>Port</th>
            <th>URL/Path</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Urls != null && Model.Urls.Any())
        {
            @foreach (var url in Model.Urls)
            {
                <tr>
                    <td>@url.Name</td>
                    <td>@url.Server</td>
                    <td>@url.IpAddress</td>
                    <td>@url.Port</td>
                    <td>@url.UrlPath</td>
                    <td>
                        <span class="status-badge @url.Status">@url.Status</span>
                    </td>
                    <td>
                        <button class="action-btn test" onclick="testPing(@url.Id)">
                            <i class="fas fa-play"></i> Test
                        </button>
                        <button class="action-btn edit" onclick="editUrl(@url.Id, '@url.Name', '@url.Server', '@url.IpAddress', @url.Port, '@url.UrlPath', '@url.Status', '@url.Remarks')">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <form method="post" asp-page-handler="ToggleStatus" style="display: inline;">
                            <input type="hidden" name="id" value="@url.Id" />
                            <button type="submit" class="action-btn toggle">
                                <i class="fas @(url.Status == "active" ? "fa-toggle-on" : "fa-toggle-off")"></i>
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Delete" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this URL?');">
                            <input type="hidden" name="id" value="@url.Id" />
                            <button type="submit" class="action-btn delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="no-data">
                    <i class="fas fa-info-circle"></i>
                    <p>No URLs found. Click "Add New URL" to create one.</p>
                </td>
            </tr>
        }
    </tbody>
</table>
        <!-- Pagination -->
        <div class="pagination">
            <button class="page-btn"><i class="fas fa-chevron-left"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn"><i class="fas fa-chevron-right"></i></button>
        </div>
    </div>
</div>

<!-- Add URL Modal -->
<div id="addModal" class="modal">
    <div class="modal-content">
        <form method="post" asp-page-handler="Add">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Add New URL</h3>
                <button type="button" class="close" onclick="hideAddModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" name="NewUrl.Name" class="form-control" required />
                </div>
                
                <div class="form-group">
                    <label>Server *</label>
                    <input type="text" name="NewUrl.Server" class="form-control" required />
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>IP Address *</label>
                        <input type="text" name="NewUrl.IpAddress" class="form-control" placeholder="192.168.1.100" required />
                    </div>
                    
                    <div class="form-group">
                        <label>Port *</label>
                        <input type="number" name="NewUrl.Port" class="form-control" min="1" max="65535" value="80" required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label>URL/Path *</label>
                    <input type="text" name="NewUrl.UrlPath" class="form-control" placeholder="/health" required />
                </div>
                
                <div class="form-group">
                    <label>Status</label>
                    <select name="NewUrl.Status" class="form-control">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Remarks</label>
                    <textarea name="NewUrl.Remarks" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="hideAddModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Add URL</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit URL Modal -->
<div id="editModal" class="modal">
    <div class="modal-content">
        <form method="post" asp-page-handler="Edit">
            <input type="hidden" name="id" id="editId" />
            <div class="modal-header">
                <h3><i class="fas fa-edit"></i> Edit URL</h3>
                <button type="button" class="close" onclick="hideEditModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" name="EditUrl.Name" id="editName" class="form-control" required />
                </div>
                
                <div class="form-group">
                    <label>Server *</label>
                    <input type="text" name="EditUrl.Server" id="editServer" class="form-control" required />
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>IP Address *</label>
                        <input type="text" name="EditUrl.IpAddress" id="editIpAddress" class="form-control" required />
                    </div>
                    
                    <div class="form-group">
                        <label>Port *</label>
                        <input type="number" name="EditUrl.Port" id="editPort" class="form-control" min="1" max="65535" required />
                    </div>
                </div>
                
                <div class="form-group">
                    <label>URL/Path *</label>
                    <input type="text" name="EditUrl.UrlPath" id="editUrlPath" class="form-control" required />
                </div>
                
                <div class="form-group">
                    <label>Status</label>
                    <select name="EditUrl.Status" id="editStatus" class="form-control">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Remarks</label>
                    <textarea name="EditUrl.Remarks" id="editRemarks" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="hideEditModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Test Ping Modal -->
<div id="testModal" class="modal">
    <div class="modal-content" style="width: 400px;">
        <div class="modal-header">
            <h3><i class="fas fa-play-circle"></i> Test Ping</h3>
            <button type="button" class="close" onclick="hideTestModal()">&times;</button>
        </div>
        <div class="modal-body" style="text-align: center; padding: 30px;">
            <div id="testLoading" style="display: none;">
                <i class="fas fa-spinner fa-spin" style="font-size: 48px; color: #007bff; margin-bottom: 15px;"></i>
                <p>Testing connection...</p>
            </div>
            <div id="testResult" style="display: none;">
                <i id="testIcon" class="fas fa-check-circle" style="font-size: 48px; margin-bottom: 15px;"></i>
                <h3 id="testStatus"></h3>
                <p id="testMessage"></p>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="hideTestModal()">Close</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal functions
        function showAddModal() {
            document.getElementById('addModal').classList.add('show');
        }
        
        function hideAddModal() {
            document.getElementById('addModal').classList.remove('show');
        }
        
        function showEditModal() {
            document.getElementById('editModal').classList.add('show');
        }
        
        function hideEditModal() {
            document.getElementById('editModal').classList.remove('show');
        }
        
        function showTestModal() {
            document.getElementById('testModal').classList.add('show');
        }
        
        function hideTestModal() {
            document.getElementById('testModal').classList.remove('show');
            document.getElementById('testLoading').style.display = 'none';
            document.getElementById('testResult').style.display = 'none';
        }
        
        // Edit URL function
        function editUrl(id, name, server, ipAddress, port, urlPath, status, remarks) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editServer').value = server;
            document.getElementById('editIpAddress').value = ipAddress;
            document.getElementById('editPort').value = port;
            document.getElementById('editUrlPath').value = urlPath;
            document.getElementById('editStatus').value = status;
            document.getElementById('editRemarks').value = remarks || '';
            showEditModal();
        }
        
        // Test ping function
        function testPing(id) {
            showTestModal();
            document.getElementById('testLoading').style.display = 'block';
            document.getElementById('testResult').style.display = 'none';
            
            // Simulate ping test
            setTimeout(function() {
                document.getElementById('testLoading').style.display = 'none';
                document.getElementById('testResult').style.display = 'block';
                
                var success = Math.random() > 0.3;
                var icon = document.getElementById('testIcon');
                var status = document.getElementById('testStatus');
                var message = document.getElementById('testMessage');
                
                if (success) {
                    var responseTime = Math.floor(Math.random() * 500) + 50;
                    icon.className = 'fas fa-check-circle';
                    icon.style.color = '#28a745';
                    status.textContent = 'Success!';
                    status.style.color = '#28a745';
                    message.textContent = `Response time: ${responseTime}ms`;
                } else {
                    icon.className = 'fas fa-times-circle';
                    icon.style.color = '#dc3545';
                    status.textContent = 'Failed!';
                    status.style.color = '#dc3545';
                    message.textContent = 'Connection timeout';
                }
            }, 1500);
        }
        
        // Close modals when clicking outside
        window.onclick = function(event) {
            var addModal = document.getElementById('addModal');
            var editModal = document.getElementById('editModal');
            var testModal = document.getElementById('testModal');
            
            if (event.target == addModal) {
                hideAddModal();
            }
            if (event.target == editModal) {
                hideEditModal();
            }
            if (event.target == testModal) {
                hideTestModal();
            }

            setTimeout(function() {
                var alerts = document.querySelectorAll('alert');
                alerts.forEach(function(alert) {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(function() {
                        alert.remove();
                    }, 500);
                });
            }, 5000);
            </script>
        }