@page
@model SystemSettingsModel
@{
    ViewData["Title"] = "System Settings";
    Layout = "_SystemAdminLayout";
}

<link rel="stylesheet" href="~/css/admin/system-settings.css" />

<div class="settings-container">
    <!-- Header -->
    <div class="header-section">
        <div class="header-title">
            <h1><i class="fas fa-cog"></i> System Settings</h1>
            <p>Configure system parameters and settings</p>
        </div>
        <button class="refresh-btn" onclick="location.reload()">
            <i class="fas fa-sync-alt"></i> Refresh
        </button>
    </div>

    <!-- Success/Error Messages -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @Model.SuccessMessage
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <!-- Tabs -->
    <div class="tabs-section">
        <div class="tabs-header">
            <button class="tab-btn active" onclick="showTab('source-fund')">
                <i class="fas fa-coins"></i> Source of Fund
            </button>
            <button class="tab-btn" onclick="showTab('parameters')">
                <i class="fas fa-sliders-h"></i> System Parameters
            </button>
            <button class="tab-btn" onclick="showTab('security')">
                <i class="fas fa-shield-alt"></i> Security Settings
            </button>
            <button class="tab-btn" onclick="showTab('notifications')">
                <i class="fas fa-bell"></i> Notifications
            </button>
        </div>

        <!-- Source of Fund Tab -->
        <div id="source-fund-tab" class="tab-content active">
            <div class="section-header">
                <h2>Source of Fund Management</h2>
                <button class="add-btn" onclick="showAddFundModal()">
                    <i class="fas fa-plus"></i> Add Source of Fund
                </button>
            </div>

            <div class="table-responsive">
                <table class="settings-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Fund Name</th>
                            <th>Code</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th>Updated Date</th>
                            <th>Created By</th>
                            <th>Remarks</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SourceOfFunds != null && Model.SourceOfFunds.Any())
                        {
                            @foreach (var fund in Model.SourceOfFunds)
                            {
                                <tr>
                                    <td>@fund.Id</td>
                                    <td>@fund.Name</td>
                                    <td><strong>@fund.Code</strong></td>
                                    <td>@fund.Description</td>
                                    <td>
                                        <span class="status-badge @fund.Status">@fund.Status</span>
                                    </td>
                                    <td>@fund.CreatedDate.ToString("yyyy-MM-dd")</td>
                                    <td>@fund.UpdatedDate.ToString("yyyy-MM-dd")</td>
                                    <td>@fund.CreatedBy</td>
                                    <td>@fund.Remarks</td>
                                    <td>
                                        <button class="action-btn edit" onclick="editFund(@fund.Id, '@fund.Name', '@fund.Code', '@fund.Description', '@fund.Status', '@fund.Remarks')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <form method="post" asp-page-handler="ToggleFundStatus" style="display: inline;">
                                            <input type="hidden" name="id" value="@fund.Id" />
                                            <button type="submit" class="action-btn toggle">
                                                <i class="fas @(fund.Status == "active" ? "fa-toggle-on" : "fa-toggle-off")"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="DeleteFund" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this fund?');">
                                            <input type="hidden" name="id" value="@fund.Id" />
                                            <button type="submit" class="action-btn delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center">No source of funds found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- System Parameters Tab -->
        <div id="parameters-tab" class="tab-content">
            <div class="parameters-grid">
                @if (Model.SystemParameters != null)
                {
                    @foreach (var category in Model.SystemParameters.Keys)
                    {
                        <div class="parameter-card">
                            <div class="parameter-header">
                                <h3>@category</h3>
                            </div>
                            <div class="parameter-body">
                                @foreach (var param in Model.SystemParameters[category])
                                {
                                    <div class="parameter-row">
                                        <div>
                                            <div class="parameter-label">@param.Name</div>
                                            <div class="parameter-description">@param.Description</div>
                                        </div>
                                        <div>
                                            <span class="parameter-value">@param.Value</span>
                                            @if (param.Editable)
                                            {
                                                <button class="edit-param-btn" onclick="editParameter('@param.Id', '@param.Name', '@param.Value', '@param.DataType')">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Security Settings Tab -->
        <div id="security-tab" class="tab-content">
            <div class="security-grid">
                <div class="security-card">
                    <div class="security-header">
                        <h3>Password Policy</h3>
                    </div>
                    <div class="security-body">
                        <div class="security-item">
                            <span class="security-label">Minimum Length</span>
                            <span class="security-value">8 characters</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Require Special Characters</span>
                            <span class="security-value">Yes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Require Numbers</span>
                            <span class="security-value">Yes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Require Uppercase</span>
                            <span class="security-value">Yes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Password History</span>
                            <span class="security-value">12 passwords</span>
                        </div>
                    </div>
                </div>

                <div class="security-card">
                    <div class="security-header">
                        <h3>Account Security</h3>
                    </div>
                    <div class="security-body">
                        <div class="security-item">
                            <span class="security-label">Session Timeout</span>
                            <span class="security-value">10 minutes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Max Login Attempts</span>
                            <span class="security-value">3 attempts</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Lockout Duration</span>
                            <span class="security-value">30 minutes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Dormant Account</span>
                            <span class="security-value">30 days</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Two-Factor Auth</span>
                            <span class="security-value">Disabled</span>
                        </div>
                    </div>
                </div>

                <div class="security-card">
                    <div class="security-header">
                        <h3>Password Expiry</h3>
                    </div>
                    <div class="security-body">
                        <div class="security-item">
                            <span class="security-label">Admin Accounts</span>
                            <span class="security-value">30 days</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">User Accounts</span>
                            <span class="security-value">90 days</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Reminder Period</span>
                            <span class="security-value">7 days before</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">Force Change on First Login</span>
                            <span class="security-value">Yes</span>
                        </div>
                    </div>
                </div>

                <div class="security-card">
                    <div class="security-header">
                        <h3>Encryption & Security</h3>
                    </div>
                    <div class="security-body">
                        <div class="security-item">
                            <span class="security-label">TLS Version</span>
                            <span class="security-value">1.2+</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">HTTPS</span>
                            <span class="security-value">Enabled</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">OWASP Compliance</span>
                            <span class="security-value">Yes</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">SQL Injection Protection</span>
                            <span class="security-value">Enabled</span>
                        </div>
                        <div class="security-item">
                            <span class="security-label">XSS Protection</span>
                            <span class="security-value">Enabled</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Tab -->
        <div id="notifications-tab" class="tab-content">
            <div class="parameters-grid">
                <div class="parameter-card">
                    <div class="parameter-header">
                        <h3>Email Notifications</h3>
                    </div>
                    <div class="parameter-body">
                        <div class="parameter-row">
                            <span class="parameter-label">System Alerts</span>
                            <span class="parameter-value">admin@ctbc.com</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Ping Failures</span>
                            <span class="parameter-value">alerts@ctbc.com</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Password Expiry</span>
                            <span class="parameter-value">users@ctbc.com</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Report Recipients</span>
                            <span class="parameter-value">reports@ctbc.com</span>
                        </div>
                    </div>
                </div>

                <div class="parameter-card">
                    <div class="parameter-header">
                        <h3>Alert Settings</h3>
                    </div>
                    <div class="parameter-body">
                        <div class="parameter-row">
                            <span class="parameter-label">Email Alerts</span>
                            <span class="parameter-value">Enabled</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Sound Alerts</span>
                            <span class="parameter-value">Enabled</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Browser Notifications</span>
                            <span class="parameter-value">Disabled</span>
                        </div>
                        <div class="parameter-row">
                            <span class="parameter-label">Alert Cooldown</span>
                            <span class="parameter-value">5 minutes</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Fund Modal -->
    <div id="addFundModal" class="modal">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddFund">
                <div class="modal-header">
                    <h3><i class="fas fa-plus-circle"></i> Add Source of Fund</h3>
                    <button type="button" class="close" onclick="hideAddFundModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Fund Name *</label>
                        <input type="text" name="NewFund.Name" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Fund Code *</label>
                        <input type="text" name="NewFund.Code" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="NewFund.Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select name="NewFund.Status" class="form-control">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea name="NewFund.Remarks" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="hideAddFundModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Fund</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Fund Modal -->
    <div id="editFundModal" class="modal">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditFund">
                <input type="hidden" name="id" id="editFundId" />
                <div class="modal-header">
                    <h3><i class="fas fa-edit"></i> Edit Source of Fund</h3>
                    <button type="button" class="close" onclick="hideEditFundModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Fund Name *</label>
                        <input type="text" name="EditFund.Name" id="editFundName" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Fund Code *</label>
                        <input type="text" name="EditFund.Code" id="editFundCode" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="EditFund.Description" id="editFundDesc" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select name="EditFund.Status" id="editFundStatus" class="form-control">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea name="EditFund.Remarks" id="editFundRemarks" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="hideEditFundModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Parameter Modal -->
    <div id="editParamModal" class="modal">
        <div class="modal-content" style="width: 400px;">
            <form method="post" asp-page-handler="SaveParameter">
                <input type="hidden" name="EditParameter.Id" id="editParamId" />
                <div class="modal-header">
                    <h3><i class="fas fa-sliders-h"></i> Edit Parameter</h3>
                    <button type="button" class="close" onclick="hideEditParamModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label id="editParamLabel">Parameter Name</label>
                        <input type="text" name="EditParameter.Name" id="editParamName" class="form-control" readonly />
                    </div>
                    <div class="form-group">
                        <label>Value</label>
                        <input type="text" name="EditParameter.Value" id="editParamValue" class="form-control" />
                    </div>
                    <input type="hidden" name="EditParameter.DataType" id="editParamDataType" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="hideEditParamModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            
            document.getElementById(tabName + '-tab').classList.add('active');
            event.target.classList.add('active');
        }

        // Add Fund Modal
        function showAddFundModal() {
            document.getElementById('addFundModal').classList.add('show');
        }
        
        function hideAddFundModal() {
            document.getElementById('addFundModal').classList.remove('show');
        }

        // Edit Fund Modal
        function editFund(id, name, code, description, status, remarks) {
            document.getElementById('editFundId').value = id;
            document.getElementById('editFundName').value = name;
            document.getElementById('editFundCode').value = code;
            document.getElementById('editFundDesc').value = description;
            document.getElementById('editFundStatus').value = status;
            document.getElementById('editFundRemarks').value = remarks || '';
            document.getElementById('editFundModal').classList.add('show');
        }
        
        function hideEditFundModal() {
            document.getElementById('editFundModal').classList.remove('show');
        }

        // Edit Parameter Modal
        function editParameter(id, name, value, dataType) {
            document.getElementById('editParamId').value = id;
            document.getElementById('editParamName').value = name;
            document.getElementById('editParamValue').value = value;
            document.getElementById('editParamDataType').value = dataType;
            document.getElementById('editParamLabel').innerText = name;
            document.getElementById('editParamModal').classList.add('show');
        }
        
        function hideEditParamModal() {
            document.getElementById('editParamModal').classList.remove('show');
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('show');
            }
        }

        // Auto-hide alerts
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(alert => {
                alert.style.transition = 'opacity 0.5s';
                alert.style.opacity = '0';
                setTimeout(() => alert.style.display = 'none', 500);
            });
        }, 5000);
    </script>
}