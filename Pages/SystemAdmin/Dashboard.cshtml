@page
@model DashboardModel
@{
    ViewData["Title"] = "System Admin Dashboard";
    Layout = "_SystemAdminLayout";
}

<link rel="stylesheet" href="~/css/admin/dashboard.css" />

<!-- Styled Welcome Section -->
<div class="welcome-section">
    <div class="welcome-card">
        <h2>System Admin Dashboard</h2>
        <p>Welcome back, System Administrator. Here's your system overview.</p>
        <div class="welcome-stats">
            <div class="welcome-stat">
                <span class="stat-label">Last Login</span>
                <span class="stat-value">Today 10:30 AM</span>
            </div>
            <div class="welcome-stat">
                <span class="stat-label">Active Sessions</span>
                <span class="stat-value">1</span>
            </div>
            <div class="welcome-stat">
                <span class="stat-label">System Health</span>
                <span class="stat-value good">Good</span>
            </div>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <h3>Total URLs</h3>
        <div class="stat-value">24</div>
        <div class="stat-label">Active monitored endpoints</div>
    </div>
    
    <div class="stat-card">
        <h3>Online</h3>
        <div class="stat-value" style="color: #10b981;">18</div>
        <div class="stat-label">Services operational</div>
    </div>
    
    <div class="stat-card">
        <h3>Offline</h3>
        <div class="stat-value" style="color: #ef4444;">6</div>
        <div class="stat-label">Services down</div>
    </div>
    
    <div class="stat-card">
        <h3>Alerts</h3>
        <div class="stat-value" style="color: #f59e0b;">3</div>
        <div class="stat-label">Pending issues</div>
    </div>
</div>

<!-- URL Monitoring Table -->
<div class="table-container">
    <div class="table-header">
        <h2><i class="fas fa-link"></i> URL Monitoring</h2>
        <div>
            <input type="text" class="search-box" placeholder="Search URLs..." id="searchInput" />
            <a href="/SystemAdmin/UrlManagement" class="add-btn">
                <i class="fas fa-plus"></i> Manage URLs
            </a>
        </div>
    </div>
    
    <table id="urlTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Server</th>
                <th>IP Address</th>
                <th>Port</th>
                <th>URL/Path</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong>Main API</strong></td>
                <td>api-server-01</td>
                <td>192.168.1.100</td>
                <td>443</td>
                <td>/health</td>
                <td><span class="status-badge active">Active</span></td>
                <td>
                    <a href="/SystemAdmin/UrlManagement" class="action-btn" title="Edit">
                        <i class="fas fa-edit"></i>
                    </a>
                    <button class="action-btn" title="Test" onclick="testPing('Main API')">
                        <i class="fas fa-play"></i>
                    </button>
                </td>
            </tr>
            <tr>
                <td><strong>Database</strong></td>
                <td>db-server-01</td>
                <td>192.168.1.200</td>
                <td>3306</td>
                <td>/status</td>
                <td><span class="status-badge active">Active</span></td>
                <td>
                    <a href="/SystemAdmin/UrlManagement" class="action-btn" title="Edit">
                        <i class="fas fa-edit"></i>
                    </a>
                    <button class="action-btn" title="Test" onclick="testPing('Database')">
                        <i class="fas fa-play"></i>
                    </button>
                </td>
            </tr>
            <tr>
                <td><strong>Payment Gateway</strong></td>
                <td>pay-server-01</td>
                <td>192.168.1.30</td>
                <td>8443</td>
                <td>/check</td>
                <td><span class="status-badge inactive">Inactive</span></td>
                <td>
                    <a href="/SystemAdmin/UrlManagement" class="action-btn" title="Edit">
                        <i class="fas fa-edit"></i>
                    </a>
                    <button class="action-btn" title="Test" onclick="testPing('Payment Gateway')">
                        <i class="fas fa-play"></i>
                    </button>
                </td>
            </tr>
        </tbody>
    </table>
    
    <div class="pagination">
        <button class="page-btn"><i class="fas fa-chevron-left"></i></button>
        <button class="page-btn active">1</button>
        <button class="page-btn">2</button>
        <button class="page-btn">3</button>
        <button class="page-btn"><i class="fas fa-chevron-right"></i></button>
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var searchTerm = this.value.toLowerCase();
            var rows = document.querySelectorAll('#urlTable tbody tr');
            
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                row.style.display = text.indexOf(searchTerm) > -1 ? '' : 'none';
            });
        });
        
        // Test ping function
        function testPing(serviceName) {
            alert(`Testing connection to ${serviceName}...`);
            // In production, this would make an actual API call
        }
    </script>
}