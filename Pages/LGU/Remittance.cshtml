@page
@model CTBCServiceStatusDashboard.Pages.LGU.RemittanceModel
@{
    ViewData["Title"] = "LGU Remittances";
    Layout = "_LguLayout";
}

<link rel="stylesheet" href="~/css/shared/theme.css" />
<link rel="stylesheet" href="~/css/lgu/remittance.css" />

<div class="remittance-container">
    <div class="header-section">
        <div class="header-title">
            <h1><i class="fas fa-hand-holding-usd"></i> LGU Remittances</h1>
            <p>Track all fund remittances to your LGU</p>
        </div>
        <button class="export-btn" onclick="exportData()">
            <i class="fas fa-download"></i> Export to Excel
        </button>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <h3>Total Remittances</h3>
            <div class="stat-value">₱@Model.TotalRemittances.ToString("N0")</div>
            <div class="stat-period">Last 6 months</div>
        </div>
        <div class="stat-card">
            <h3>Average Monthly</h3>
            <div class="stat-value">₱@Model.AverageMonthly.ToString("N0")</div>
            <div class="stat-period">Regular IRA: ₱245,000/month</div>
        </div>
    </div>

    <div class="filter-section">
        <div class="filter-group">
            <label>From Date</label>
            <input type="date" class="filter-control" id="fromDate" />
        </div>
        <div class="filter-group">
            <label>To Date</label>
            <input type="date" class="filter-control" id="toDate" />
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select class="filter-control" id="statusFilter">
                <option value="all">All Status</option>
                <option value="Received">Received</option>
                <option value="Pending">Pending</option>
            </select>
        </div>
    </div>

    <div class="table-responsive">
        <table class="remittance-table" id="remittanceTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Source</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Reference</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Remittances)
                {
                    <tr>
                        <td>@item.Date</td>
                        <td>@item.Source</td>
                        <td>@item.Description</td>
                        <td class="amount">₱@item.Amount.ToString("N0")</td>
                        <td>
                            <span class="status-badge status-@item.Status.ToLower()">@item.Status</span>
                        </td>
                        <td class="reference">@item.Reference</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="pagination">
            <button class="page-btn"><i class="fas fa-chevron-left"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn"><i class="fas fa-chevron-right"></i></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function exportData() {
            alert('Exporting data... In production, this would download an Excel file.');
        }

        // Simple filter (in production, this would use server-side filtering)
        document.getElementById('fromDate').addEventListener('change', filterTable);
        document.getElementById('toDate').addEventListener('change', filterTable);
        document.getElementById('statusFilter').addEventListener('change', filterTable);

        function filterTable() {
            // In production, this would reload the page with filters
            alert('Filters applied. In production, this would refresh the data.');
        }
    </script>
}