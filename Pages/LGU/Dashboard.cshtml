@page
@model CTBCServiceStatusDashboard.Pages.LGU.DashboardModel
@{
    ViewData["Title"] = "LGU Dashboard";
    Layout = "_LguLayout";
}

<link rel="stylesheet" href="~/css/shared/theme.css" />
<link rel="stylesheet" href="~/css/lgu/dashboard.css" />

<div class="lgu-dashboard">
    <!-- Welcome Section -->
    <div class="welcome-section">
        <h1>Welcome back, @(User.FindFirst("FullName")?.Value ?? "LGU User")!</h1>
        <p>Here's your local government unit dashboard overview.</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon projects">
                <i class="fas fa-project-diagram"></i>
            </div>
            <div class="stat-details">
                <h3>Total Projects</h3>
                <div class="stat-value">@Model.TotalProjects</div>
                <div class="stat-label">Active: @Model.ActiveProjects</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon active">
                <i class="fas fa-play-circle"></i>
            </div>
            <div class="stat-details">
                <h3>Active Projects</h3>
                <div class="stat-value">@Model.ActiveProjects</div>
                <div class="stat-label">In progress</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon completed">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-details">
                <h3>Completed</h3>
                <div class="stat-value">@Model.CompletedProjects</div>
                <div class="stat-label">Projects finished</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon remittance">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div class="stat-details">
                <h3>Total Remittances</h3>
                <div class="stat-value">₱@Model.TotalRemittances.ToString("N0")</div>
                <div class="stat-label">Monthly: ₱@Model.MonthlyRemittance.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Projects Section -->
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-tasks"></i> Ongoing Projects</h3>
                <a href="/LGU/Projects" class="view-all-link">View All →</a>
            </div>
            <div class="card-body">
                <ul class="project-list">
                    <li class="project-item">
                        <div class="project-info">
                            <h4>Road Construction - Phase 2</h4>
                            <p>Barangay San Jose • Started Jan 2024</p>
                        </div>
                        <div class="project-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 75%"></div>
                            </div>
                            <span class="project-status status-active">75%</span>
                        </div>
                    </li>
                    <li class="project-item">
                        <div class="project-info">
                            <h4>School Building Construction</h4>
                            <p>Barangay Santo Niño • Started Mar 2024</p>
                        </div>
                        <div class="project-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 30%"></div>
                            </div>
                            <span class="project-status status-active">30%</span>
                        </div>
                    </li>
                    <li class="project-item">
                        <div class="project-info">
                            <h4>Public Market Renovation</h4>
                            <p>Barangay Poblacion • Started Feb 2024</p>
                        </div>
                        <div class="project-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 60%"></div>
                            </div>
                            <span class="project-status status-active">60%</span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Recent Remittances -->
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-hand-holding-usd"></i> Recent Remittances</h3>
                <a href="/LGU/Remittance" class="view-all-link">View All →</a>
            </div>
            <div class="card-body">
                <ul class="remittance-list">
                    <li class="remittance-item">
                        <span class="remittance-date">Mar 10, 2024</span>
                        <span class="remittance-amount">₱245,000</span>
                        <span class="remittance-status status-received">Received</span>
                    </li>
                    <li class="remittance-item">
                        <span class="remittance-date">Feb 10, 2024</span>
                        <span class="remittance-amount">₱245,000</span>
                        <span class="remittance-status status-received">Received</span>
                    </li>
                    <li class="remittance-item">
                        <span class="remittance-date">Jan 10, 2024</span>
                        <span class="remittance-amount">₱245,000</span>
                        <span class="remittance-status status-received">Received</span>
                    </li>
                    <li class="remittance-item">
                        <span class="remittance-date">Dec 10, 2023</span>
                        <span class="remittance-amount">₱510,000</span>
                        <span class="remittance-status status-received">Received</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-history"></i> Recent Activity</h3>
        </div>
        <div class="card-body">
            <ul class="activity-list">
                @foreach (var activity in Model.RecentActivities)
                {
                    <li class="activity-item">
                        <div class="activity-icon @activity.Color">
                            <i class="fas @activity.Icon"></i>
                        </div>
                        <div class="activity-details">
                            <div class="activity-title">@activity.Title</div>
                            <div class="activity-desc">@activity.Description</div>
                        </div>
                        <div class="activity-time">@activity.Time</div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>