@page
@model CTBCServiceStatusDashboard.Pages.LGU.ProjectsModel
@{
    ViewData["Title"] = "LGU Projects";
    Layout = "_LguLayout";
}

<link rel="stylesheet" href="~/css/shared/theme.css" />
<link rel="stylesheet" href="~/css/lgu/projects.css" />    

<div class="projects-container">
    <div class="header-section">
        <div class="header-title">
            <h1><i class="fas fa-project-diagram"></i> LGU Projects</h1>
            <p>View and track all local government projects</p>
        </div>
        <div class="filter-section">
            <input type="text" class="search-box" placeholder="Search projects..." id="searchInput" />
            <select class="filter-select" id="statusFilter">
                <option value="all">All Status</option>
                <option value="Active">Active</option>
                <option value="Planning">Planning</option>
                <option value="Completed">Completed</option>
            </select>
        </div>
    </div>

    <div class="projects-grid" id="projectsGrid">
        @foreach (var project in Model.Projects)
        {
            <div class="project-card" data-status="@project.Status">
                <div class="project-header">
                    <h3>@project.Name</h3>
                    <p><i class="fas fa-map-marker-alt"></i> @project.Location</p>
                </div>
                <div class="project-body">
                    <div class="project-info">
                        <div class="info-row">
                            <span class="info-label">Timeline:</span>
                            <span class="info-value">@project.StartDate to @project.EndDate</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Contractor:</span>
                            <span class="info-value">@project.Contractor</span>
                        </div>
                    </div>

                    <div class="progress-section">
                        <div class="progress-header">
                            <span class="progress-label">Progress</span>
                            <span class="progress-percent">@project.Progress%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill @project.Status.ToLower()" style="width: @project.Progress%"></div>
                        </div>
                    </div>
                </div>
                <div class="project-footer">
                    <span class="budget">₱@project.Budget.ToString("N0")</span>
                    <span class="status-badge @project.Status.ToLower()">@project.Status</span>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Filter functionality
        document.getElementById('searchInput').addEventListener('keyup', filterProjects);
        document.getElementById('statusFilter').addEventListener('change', filterProjects);

        function filterProjects() {
            var searchTerm = document.getElementById('searchInput').value.toLowerCase();
            var statusFilter = document.getElementById('statusFilter').value;
            var projects = document.querySelectorAll('.project-card');

            projects.forEach(function(project) {
                var title = project.querySelector('.project-header h3').textContent.toLowerCase();
                var location = project.querySelector('.project-header p').textContent.toLowerCase();
                var status = project.getAttribute('data-status');

                var matchesSearch = title.includes(searchTerm) || location.includes(searchTerm);
                var matchesStatus = statusFilter === 'all' || status === statusFilter;

                if (matchesSearch && matchesStatus) {
                    project.style.display = '';
                } else {
                    project.style.display = 'none';
                }
            });
        }
    </script>
}