@page
@model CTBCServiceStatusDashboard.Pages.UserAdmin.RoleManagementModel
@{
    ViewData["Title"] = "Role Management";
    Layout = "_UserAdminLayout";
}

<link rel="stylesheet" href="~/css/useradmin/role-management.css" />

<div class="role-container">
    <div class="header-section">
        <div class="header-title">
            <h1><i class="fas fa-shield-alt"></i> Role Management</h1>
            <p>Manage user roles and permissions</p>
        </div>
        <button class="add-btn" onclick="showAddRoleModal()">
            <i class="fas fa-plus"></i> Add New Role
        </button>
    </div>

    <div class="table-responsive">
        <table class="role-table">
            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Description</th>
                    <th>Users</th>
                    <th>Permissions</th>
                    <th>Status</th>
                    <th>Last Modified</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="role-badge system-admin">System Admin</span></td>
                    <td>Full system access</td>
                    <td>2</td>
                    <td>20 permissions</td>
                    <td><span class="status-badge active">Active</span></td>
                    <td>2024-03-01</td>
                    <td>
                        <button class="action-btn edit" onclick="editRole(1)" title="Edit Role">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn permissions" onclick="managePermissions(1)" title="Manage Permissions">
                            <i class="fas fa-key"></i>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td><span class="role-badge user-admin">User Admin</span></td>
                    <td>Manage users and LGU modules</td>
                    <td>3</td>
                    <td>12 permissions</td>
                    <td><span class="status-badge active">Active</span></td>
                    <td>2024-02-15</td>
                    <td>
                        <button class="action-btn edit" onclick="editRole(2)" title="Edit Role">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn permissions" onclick="managePermissions(2)" title="Manage Permissions">
                            <i class="fas fa-key"></i>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td><span class="role-badge lgu">LGU User</span></td>
                    <td>LGU portal access</td>
                    <td>8</td>
                    <td>6 permissions</td>
                    <td><span class="status-badge active">Active</span></td>
                    <td>2024-02-10</td>
                    <td>
                        <button class="action-btn edit" onclick="editRole(3)" title="Edit Role">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn permissions" onclick="managePermissions(3)" title="Manage Permissions">
                            <i class="fas fa-key"></i>
                        </button>
                    </td>
                </tr>
                <tr>
                    <td><span class="role-badge user">Regular User</span></td>
                    <td>Basic service monitoring</td>
                    <td>15</td>
                    <td>4 permissions</td>
                    <td><span class="status-badge active">Active</span></td>
                    <td>2024-01-20</td>
                    <td>
                        <button class="action-btn edit" onclick="editRole(4)" title="Edit Role">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn permissions" onclick="managePermissions(4)" title="Manage Permissions">
                            <i class="fas fa-key"></i>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
        
        <div class="pagination">
            <button class="page-btn"><i class="fas fa-chevron-left"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn"><i class="fas fa-chevron-right"></i></button>
        </div>
    </div>
</div>

<!-- Permissions Modal -->
<div id="permissionsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-key"></i> Manage Permissions</h3>
            <button type="button" class="close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="permission-group">
                <h4>Dashboard Access</h4>
                <div class="permission-item">
                    <input type="checkbox" id="viewDashboard" checked />
                    <label for="viewDashboard">View Dashboard</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="viewStats" checked />
                    <label for="viewStats">View Statistics</label>
                </div>
            </div>
            
            <div class="permission-group">
                <h4>User Management</h4>
                <div class="permission-item">
                    <input type="checkbox" id="viewUsers" checked />
                    <label for="viewUsers">View Users</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="createUsers" checked />
                    <label for="createUsers">Create Users</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="editUsers" checked />
                    <label for="editUsers">Edit Users</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="deleteUsers" />
                    <label for="deleteUsers">Delete Users</label>
                </div>
            </div>
            
            <div class="permission-group">
                <h4>LGU Modules</h4>
                <div class="permission-item">
                    <input type="checkbox" id="viewLGU" checked />
                    <label for="viewLGU">View LGU Dashboard</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="viewProjects" checked />
                    <label for="viewProjects">View Projects</label>
                </div>
                <div class="permission-item">
                    <input type="checkbox" id="viewRemittances" checked />
                    <label for="viewRemittances">View Remittances</label>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" onclick="savePermissions()">Save Changes</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Show add role modal
        function showAddRoleModal() {
            alert('Add Role modal would open here. In production, this would open a form to create a new role.');
        }
        
        // Edit role
        function editRole(id) {
            alert('Edit Role ' + id + ' - In production, this would open an edit form.');
        }
        
        // Manage permissions
        function managePermissions(id) {
            document.getElementById('permissionsModal').classList.add('show');
        }
        
        // Close modal
        function closeModal() {
            document.getElementById('permissionsModal').classList.remove('show');
        }
        
        // Save permissions
        function savePermissions() {
            alert('Permissions saved successfully!');
            closeModal();
        }
        
        // Close modal when clicking outside
        window.onclick = function(event) {
            var modal = document.getElementById('permissionsModal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
}