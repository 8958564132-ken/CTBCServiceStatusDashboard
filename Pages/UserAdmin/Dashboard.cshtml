@page
@model CTBCServiceStatusDashboard.Pages.UserAdmin.DashboardModel
@{
    ViewData["Title"] = "User Admin Dashboard";
    Layout = "_UserAdminLayout";
}

<link rel="stylesheet" href="~/css/useradmin/dashboard.css" />

<div class="welcome-section">
    <h1>Welcome back, @(User.FindFirst("FullName")?.Value ?? "User Admin")!</h1>
    <p>Monitor service status and manage users from your dashboard.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-value">@Model.TotalUsers</div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-user-check"></i>
        </div>
        <div class="stat-value">@Model.ActiveUsers</div>
        <div class="stat-label">Active Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-user-clock"></i>
        </div>
        <div class="stat-value">@Model.PendingActions</div>
        <div class="stat-label">Pending Actions</div>
    </div>
</div>

<div class="quick-actions">
    <a href="/UserAdmin/AddUser" class="action-card">
        <div class="action-icon">
            <i class="fas fa-user-plus"></i>
        </div>
        <div class="action-title">Add New User</div>
        <div class="action-desc">Create a new user account (User or LGU only)</div>
    </a>
    
    <a href="/UserAdmin/UserList" class="action-card">
        <div class="action-icon">
            <i class="fas fa-list"></i>
        </div>
        <div class="action-title">View Users</div>
        <div class="action-desc">Manage existing users and their permissions</div>
    </a>
</div>
</div>

<!-- Recent Activity -->
<div class="recent-activity">
    <div class="activity-header">
        <h3><i class="fas fa-history"></i> Recent Activity</h3>
        <span class="badge bg-success">Live</span>
    </div>
    
    @foreach (var activity in Model.RecentActivities)
    {
        <div class="activity-item">
            <div class="activity-icon @activity.Color">
                <i class="fas @activity.Icon"></i>
            </div>
            <div class="activity-details">
                <div class="activity-user">@activity.Title</div>
                <div class="activity-meta">@activity.Description</div>
            </div>
            <div class="activity-time">@activity.Time</div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            var searchTerm = this.value.toLowerCase();
            var rows = document.querySelectorAll('#serviceTable tbody tr');
            
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                row.style.display = text.indexOf(searchTerm) > -1 ? '' : 'none';
            });
        });
        
        // Refresh button
        document.getElementById('refreshServices')?.addEventListener('click', function() {
            var btn = this;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
            
            setTimeout(function() {
                location.reload();
            }, 1000);
        });
        
        // Test button functionality
        document.querySelectorAll('.test-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';
                this.disabled = true;
                
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.disabled = false;
                    
                    // Randomly update status for demo
                    var row = this.closest('tr');
                    var statusCell = row.querySelector('.status-badge');
                    var lastCheckedCell = row.cells[6];
                    
                    if (Math.random() > 0.3) {
                        statusCell.className = 'status-badge active';
                        statusCell.textContent = 'Online';
                    } else {
                        statusCell.className = 'status-badge inactive';
                        statusCell.textContent = 'Offline';
                    }
                    
                    lastCheckedCell.textContent = 'Just now';
                }, 1500);
            });
        });
    </script>
}