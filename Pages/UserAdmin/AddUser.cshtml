@page
@model CTBCServiceStatusDashboard.Pages.UserAdmin.AddUserModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit User" : "Add User";
    Layout = "_UserAdminLayout";
}

<link rel="stylesheet" href="~/css/useradmin/adduser.css" />

<div class="form-container">
    <div class="form-header">
        <h1>
            <i class="fas @(Model.IsEdit ? "fa-user-edit" : "fa-user-plus")"></i>
            @(Model.IsEdit ? "Edit User" : "Add New User")
        </h1>
        <p>@(Model.IsEdit ? "Update user information" : "Create a new user account (regular user or LGU only)")</p>
    </div>
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }
    
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        <strong>Note:</strong> User Admins can only create Regular Users and LGU Users. Admin roles cannot be created.
    </div>
    
    <form method="post">
        @if (Model.IsEdit)
        {
            <input type="hidden" name="User.Id" value="@Model.User.Id" />
        }
        
        <div class="form-row">
            <div class="form-group">
                <label>First Name <span class="required">*</span></label>
                <input type="text" 
                       name="User.FirstName" 
                       class="form-control" 
                       value="@(Model.User?.FirstName ?? "")" 
                       required 
                       maxlength="50" />
            </div>
            <div class="form-group">
                <label>Last Name <span class="required">*</span></label>
                <input type="text" 
                       name="User.LastName" 
                       class="form-control" 
                       value="@(Model.User?.LastName ?? "")" 
                       required 
                       maxlength="50" />
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-group">
                <label>Username <span class="required">*</span></label>
                <input type="text" 
                       name="User.Username" 
                       class="form-control" 
                       value="@(Model.User?.Username ?? "")" 
                       required 
                       maxlength="30" />
                <small class="text-muted">Username must be unique</small>
            </div>
            <div class="form-group">
                <label>Email <span class="required">*</span></label>
                <input type="email" 
                       name="User.Email" 
                       class="form-control" 
                       value="@(Model.User?.Email ?? "")" 
                       required 
                       maxlength="100" />
            </div>
        </div>
        
        @if (!Model.IsEdit)
        {
            <div class="form-row">
                <div class="form-group">
                    <label>Password <span class="required">*</span></label>
                    <input type="password" 
                           name="Password" 
                           id="Password" 
                           class="form-control" 
                           required 
                           minlength="8" />
                    <div class="password-requirements">
                        <strong>Password must contain:</strong>
                        <ul>
                            <li id="lengthReq" class="invalid">At least 8 characters</li>
                            <li id="numberReq" class="invalid">At least one number</li>
                            <li id="specialReq" class="invalid">At least one special character</li>
                        </ul>
                    </div>
                </div>
                <div class="form-group">
                    <label>Confirm Password <span class="required">*</span></label>
                    <input type="password" 
                           name="ConfirmPassword" 
                           id="ConfirmPassword" 
                           class="form-control" 
                           required 
                           minlength="8" />
                </div>
            </div>
        }
        
        <div class="form-row">
            <div class="form-group">
                <label>Role <span class="required">*</span></label>
                <select name="User.Role" class="form-control" required>
                    <option value="">Select Role</option>
                    <option value="User" selected="@(Model.User?.Role == "User")">Regular User</option>
                    <option value="User Admin" selected="@(Model.User?.Role == "User Admin")">User Admin</option>
                    <option value="System Admin" selected="@(Model.User?.Role == "System Admin")">System Admin</option>
                </select>
            </div>
            <div class="form-group">
                <label>Status</label>
                <select name="User.Status" class="form-control">
                    <option value="active" selected="@(Model.User?.Status == "active")">Active</option>
                    <option value="inactive" selected="@(Model.User?.Status == "inactive")">Inactive</option>
                </select>
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-group">
                <label>Department</label>
                <input type="text" 
                       name="User.Department" 
                       class="form-control" 
                       value="@(Model.User?.Department ?? "")" 
                       maxlength="100" />
            </div>
        </div>
        
        <div class="form-actions">
            <button type="submit" name="handler" value="Cancel" class="btn btn-secondary" formnovalidate>
                <i class="fas fa-times"></i> Cancel
            </button>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> @(Model.IsEdit ? "Update User" : "Create User")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/adduser.js"></script>
}